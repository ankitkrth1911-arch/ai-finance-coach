# Project Name
PROJECT_NAME="AI Personal Finance Coach"

# Database connection
# For Postgres: postgresql://username:password@localhost:5432/dbname
# For SQLite (local quick testing): sqlite:///./finance_coach.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_coach

# Security Settings
# Generate a secure random string using: openssl rand -hex 32
SECRET_KEY=supersecretkeyforfinancecoachauthjwt

# Plaid API Keys (obtain from https://dashboard.plaid.com)
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US,CA

# OpenAI API Key (obtain from https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# Mail/SMTP Settings (Optional: logs to console if empty)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_EMAIL=financecoach@yourdomain.com
